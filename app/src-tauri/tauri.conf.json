{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "因为产出了很多MD文档所以需要一个简单免费的MD文件查看编辑软件",
  "version": "0.4.2",
  "identifier": "com.markdown-editor.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "因为产出了很多MD文档所以需要一个简单免费的MD文件查看编辑软件",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkd", "mkdn", "txt"],
        "mimeType": "text/markdown",
        "description": "Markdown Document"
      }
    ]
  },
  "plugins": {}
}
